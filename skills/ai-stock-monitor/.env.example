# AI Stock Monitor - 配置示例
# 复制此文件为 .env 并修改为你的配置

# ==================== Tushare 配置 ====================
TUSHARE_TOKEN=your_token_here

# ==================== Ollama 配置 ====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ==================== 系统配置 ====================
LOG_LEVEL=INFO
STREAMLIT_PORT=8501

# ==================== 监控配置 ====================
DEFAULT_STOCKS=000001.SZ,600000.SH,600030.SH,000858.SZ
MONITOR_INTERVAL=60

# ==================== API Key 管理 ====================
# 敏感信息请使用环境变量或密钥管理工具
# 不要将 API Key 提交到版本控制系统
